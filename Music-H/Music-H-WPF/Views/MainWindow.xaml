<Window x:Class="Music_H_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Music_H_WPF.Views"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        mc:Ignorable="d"
        Title="H-Music"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="0" Margin="0,0,0,16">
            <DockPanel LastChildFill="True">
                <materialDesign:ColorZone Mode="PrimaryMid" Padding="16">
                    <DockPanel LastChildFill="True">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MusicCircle" Width="28" Height="28" VerticalAlignment="Center" />
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="H-Music Player" FontSize="20" FontWeight="Bold" />
                                <TextBlock Text="你的本地音乐空间" Opacity="0.82" />
                            </StackPanel>
                        </StackPanel>

                    </DockPanel>
                </materialDesign:ColorZone>
            </DockPanel>
        </materialDesign:Card>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.8*" />
                <ColumnDefinition Width="4.2*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="播放列表" FontSize="18" FontWeight="SemiBold" Margin="4,2,0,12" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Playlist}"
                             SelectedItem="{Binding SelectedTrack}"
                             DisplayMemberPath="Title"
                             BorderThickness="0"
                             Background="Transparent" />
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <materialDesign:ColorZone Grid.Row="0"
                                              Height="180"
                                              Margin="0,0,0,16"
                                              CornerRadius="16"
                                              Mode="PrimaryLight">
                        <Grid>
                            <materialDesign:PackIcon Kind="Album" Width="72" Height="72" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </materialDesign:ColorZone>

                    <TextBlock Grid.Row="1"
                               Text="正在播放"
                               FontSize="14"
                               Opacity="0.72" />
                    <TextBlock Grid.Row="2"
                               Margin="0,6,0,18"
                               FontSize="28"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding SelectedTrack.Title, TargetNullValue=未选择歌曲}" />

                    <Slider Grid.Row="3"
                            Value="{Binding SeekValue, Mode=TwoWay}"
                            Maximum="{Binding SeekMaximum}"
                            PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp" />

                    <DockPanel Grid.Row="4" Margin="0,8,0,18">
                        <TextBlock Text="{Binding CurrentPositionText}" Opacity="0.75" />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TotalDurationText}" Opacity="0.75" />
                    </DockPanel>

                    <StackPanel Grid.Row="5" VerticalAlignment="Top">
                        <WrapPanel Margin="0,0,0,14">
                            <Button Content="上一首" Command="{Binding PreviousCommand}" Margin="0,0,10,0" Padding="16,8" MinWidth="86" />
                            <Button Content="播放" Command="{Binding PlayCommand}" Margin="0,0,10,0" Padding="16,8" MinWidth="86" />
                            <Button Content="暂停" Command="{Binding PauseCommand}" Margin="0,0,10,0" Padding="16,8" MinWidth="86" />
                            <Button Content="停止" Command="{Binding StopCommand}" Margin="0,0,10,0" Padding="16,8" MinWidth="86" />
                            <Button Content="下一首" Command="{Binding NextCommand}" Padding="16,8" MinWidth="86" />
                        </WrapPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Margin="0,0,12,0" Text="音量" />
                            <Slider Grid.Column="1"
                                    Minimum="0"
                                    Maximum="1"
                                    SmallChange="0.05"
                                    LargeChange="0.1"
                                    Value="{Binding Volume, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>
        </Grid>

        <!-- 悬浮在窗口左下角，避免被主内容区遮挡 -->
        <Button HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="24,0,0,24"
                Panel.ZIndex="1000"
                Command="{Binding ImportCommand}"
                ToolTip="导入歌曲">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFloatingActionButton}">
                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp6" />
                    <Setter Property="materialDesign:RippleAssist.Feedback" Value="#99FFFFFF" />
                    <Setter Property="materialDesign:RippleAssist.RippleSizeMultiplier" Value="1.45" />
                    <Setter Property="materialDesign:RippleAssist.RippleOnTop" Value="True" />
                    <Setter Property="materialDesign:RippleAssist.IsCentered" Value="True" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp12" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp8" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <materialDesign:PackIcon Kind="Plus" Width="24" Height="24" />
        </Button>
    </Grid>
</Window>
